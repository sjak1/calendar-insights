# ---------- Bedrock (default LLM) ----------
USE_BEDROCK=1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
AWS_REGION=us-west-2
# API key auth (boto3 reads AWS_BEARER_TOKEN_BEDROCK; we set it from bedrock_api_key)
bedrock_api_key=<your-bedrock-api-key>
# Set USE_BEDROCK=0 to use OpenAI instead

# ---------- OpenSearch ----------
OPENSEARCH_URL=https://vpc-biq-el-6btfhssa63uue6ifqd6plwcexy.us-west-2.es.amazonaws.com
OPENSEARCH_USERNAME=biq-eiq
OPENSEARCH_PASSWORD=biqXX0109##
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_TIMEOUT_SECONDS=120
OPENSEARCH_DEFAULT_INDICES=
OPENSEARCH_CONNECTION_TIMEOUT_MS=120000
OPENSEARCH_READ_TIMEOUT_MS=120000
OPENSEARCH_SOCKET_TIMEOUT_MS=120000

# ---------- Spring compatibility values ----------
spring.elasticsearch.rest.uris=https://vpc-biq-el-6btfhssa63uue6ifqd6plwcexy.us-west-2.es.amazonaws.com
spring.elasticsearch.rest.username=biq-eiq
spring.elasticsearch.rest.password=biqXX0109##
spring.elasticsearch.rest.connection-timeout=120000
spring.elasticsearch.rest.read-timeout=120000
spring.data.elasticsearch.client.reactive.use-ssl=false
spring.elasticsearch.rest.socket-timeout=120000